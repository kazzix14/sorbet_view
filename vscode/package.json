{
  "name": "sorbet-view",
  "displayName": "Sorbet View",
  "description": "ERB template type-checking and LSP support via Sorbet",
  "version": "0.1.1",
  "publisher": "kazzix14",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kazzix14/sorbet_view"
  },
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:erb",
    "onLanguage:ruby"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Sorbet View",
      "properties": {
        "sorbetView.command": {
          "type": "string",
          "default": "bundle exec sv lsp",
          "description": "Command to start the LSP server"
        },
        "sorbetView.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP communication (for debugging)"
        }
      }
    },
    "commands": [
      {
        "command": "sorbetView.restart",
        "title": "Sorbet View: Restart Server"
      }
    ]
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "vscode:prepublish": "npm run build -- --minify"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.91.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  }
}
