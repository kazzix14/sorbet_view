{
  "name": "sorbet-view",
  "displayName": "Sorbet View",
  "description": "ERB template type-checking and LSP support via Sorbet",
  "version": "0.1.0",
  "publisher": "kazzix14",
  "license": "MIT",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:erb",
    "onLanguage:ruby"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Sorbet View",
      "properties": {
        "sorbetView.command": {
          "type": "string",
          "default": "bundle exec sv lsp",
          "description": "Command to start the LSP server"
        },
        "sorbetView.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP communication (for debugging)"
        }
      }
    },
    "commands": [
      {
        "command": "sorbetView.restart",
        "title": "Sorbet View: Restart Server"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.91.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
